{
  "ignorePatterns": [
    { "pattern": "^http://localhost" },
    { "pattern": "^https://github.com/AgriciDaniel/flow" }
  ],
  "replacementPatterns": [],
  "httpHeaders": [
    {
      "urls": ["https://"],
      "headers": {
        "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
        "User-Agent": "Mozilla/5.0 (compatible; flow-link-check/1.0; +https://github.com/AgriciDaniel/flow)"
      }
    }
  ],
  "timeout": "20s",
  "retryOn429": true,
  "retryCount": 3,
  "fallbackRetryDelay": "30s",
  "aliveStatusCodes": [200, 206, 301, 302, 308, 403, 999]
}
